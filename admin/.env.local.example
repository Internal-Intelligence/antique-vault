# Solana RPC — use devnet for testing, your own RPC for production
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Your deployed Anchor program ID (from `anchor keys list` after `anchor build`)
NEXT_PUBLIC_PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Pinata JWT for IPFS uploads (get from app.pinata.cloud → API Keys)
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_here

# Optional: Pinata gateway (defaults to public gateway)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud
