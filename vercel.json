{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd customer && npm install",
  "buildCommand": "cd customer && npm run build",
  "outputDirectory": "customer/.next",
  "crons": [
    {
      "path": "/api/cron/incentive-bot",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/settle-auctions",
      "schedule": "*/10 * * * *"
    }
  ]
}